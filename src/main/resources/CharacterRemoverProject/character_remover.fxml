<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="326.0" prefWidth="501.0" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CharacterRemoverProject.CharacterRemoverController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="displayText" alignment="CENTER" prefHeight="58.0" prefWidth="415.0" text="ABCDEFGHIJKLMNOPQRSTUVWXWYZ0123456789">
      <font>
         <Font name="Arial Black" size="13.0" />
      </font></Label>
    <HBox alignment="TOP_CENTER" maxHeight="50.0" maxWidth="300.0" prefHeight="100.0" prefWidth="306.0" spacing="20.0">
        <CheckBox fx:id="chkbxVowels" mnemonicParsing="false" onMouseClicked="#onChkbxClicked" text="Vowels" />
        <CheckBox fx:id="chkbxConsonants" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onMouseClicked="#onChkbxClicked" text="Consonants" />
        <CheckBox fx:id="chkbxNumbers" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onMouseClicked="#onChkbxClicked" text="Numbers" />
    </HBox>
   <Button fx:id="btnRemove" mnemonicParsing="false" onMouseClicked="#onBtnClicked" prefHeight="26.0" prefWidth="67.0" text="Remove" />
   <Button fx:id="btnRestore" layoutX="189.0" layoutY="224.0" mnemonicParsing="false" onMouseClicked="#onBtnClicked" prefHeight="26.0" prefWidth="67.0" text="Restore" />
</VBox>
